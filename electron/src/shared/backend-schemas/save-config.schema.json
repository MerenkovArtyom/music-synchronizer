        },
        "ok": {
          "const": false,
          "title": "Ok",
          "type": "boolean"
        }
      },
      "required": [
        "ok",
        "command",
        "error"
      ],
      "title": "SaveConfigErrorEnvelope",
      "type": "object"
    },
    "SaveConfigSuccessEnvelope": {
      "additionalProperties": false,
      "properties": {
        "command": {
          "const": "save-config",
          "title": "Command",
          "type": "string"
        },
        "data": {
          "$ref": "#/$defs/SaveConfigData"
        },
        "ok": {
          "const": true,
          "title": "Ok",
          "type": "boolean"
