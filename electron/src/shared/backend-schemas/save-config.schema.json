{
  "$defs": {
    "BackendErrorPayload": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "title": "Code",
          "type": "string"
        },
        "details": {
          "additionalProperties": true,
          "default": {},
          "title": "Details",
          "type": "object"
        },
        "message": {
          "title": "Message",
          "type": "string"
        }
      },
      "required": [
        "code",
        "message"
      ],
      "title": "BackendErrorPayload",
      "type": "object"
    },
    "ConfigSummaryData": {
      "additionalProperties": false,
      "properties": {
        "discoveryPlaylistName": {
          "title": "Discoveryplaylistname",
          "type": "string"
        },
        "logLevel": {
          "title": "Loglevel",
          "type": "string"
        },
        "obsidianVaultPath": {
          "title": "Obsidianvaultpath",
          "type": "string"
        },
        "yandexMusicToken": {
          "title": "Yandexmusictoken",
          "type": "string"
        },
        "yandexMusicTokenPresent": {
          "title": "Yandexmusictokenpresent",
          "type": "boolean"
        }
      },
      "required": [
        "yandexMusicToken",
