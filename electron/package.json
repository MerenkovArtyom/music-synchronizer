{
  "name": "music-synchronizer-electron",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main/index.cjs",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run build:electron",
    "build:electron": "npm run clean && tsc --noEmit -p tsconfig.json && node ./scripts/build.mjs",
    "dev": "npm run build:electron && electron .",
    "package": "npm run package:standalone",
    "package:backend": "node ./scripts/package-backend.mjs",
    "prepare:icon": "node ./scripts/prepare-icon.mjs",
    "package:standalone": "npm run build:electron && npm run package:backend",
    "package:dmg": "npm run prepare:icon && npm run package:standalone && electron-builder --mac dmg --arm64 && node ./scripts/move-dmg.mjs",
    "package:mac": "npm run package:dmg",
    "package:mac:dir": "npm run prepare:icon && npm run package:standalone && electron-builder --mac dir --arm64",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test tests/*.test.ts"
  },
  "build": {
    "appId": "dev.artem.music-synchronizer",
    "productName": "Music Synchronizer",
    "asar": true,
    "artifactName": "Music-Synchronizer-mac-arm64.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist/package/backend",
        "to": "backend"
      }
    ],
    "mac": {
      "icon": "build/icon.png",
      "target": [
        "dmg"
      ],
      "category": "public.app-category.music"
    }
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "electron": "^37.2.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.25.11",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
